---
import PageLayout from '@layouts/PageLayout.astro'
import Container from '@components/ui/Container.astro'
import SectionHeading from '@components/ui/SectionHeading.astro'
import Breadcrumbs from '@components/global/Breadcrumbs.astro'
import ServiceCard from '@components/services/ServiceCard.astro'
import InitiativeCard from '@components/services/InitiativeCard.astro'
import ExpertProfile from '@components/services/ExpertProfile.astro'
import JoinCTA from '@components/home/JoinCTA.astro'
import { fetchSanity, urlFor } from '@lib/sanity'
import { ALL_SERVICES_QUERY, ALL_INITIATIVES_QUERY, EXPERT_MEMBERS_QUERY } from '../../sanity/lib/queries'

const fallbackServices = [
  { title: 'Representación Gremial', description: 'Defendemos los intereses del comercio organizado ante el gobierno, congreso y organismos reguladores. Participamos activamente en la formulación de políticas públicas que impactan al sector.', icon: '🏛️' },
  { title: 'Asesoría Legal', description: 'Equipo de abogados especializados en legislación comercial, laboral y tributaria dominicana. Orientación permanente para el cumplimiento normativo de tu empresa.', icon: '⚖️' },
  { title: 'Asesoría Fiscal', description: 'Expertos en materia impositiva que te ayudan a optimizar la carga tributaria de tu empresa dentro del marco legal vigente.', icon: '📊' },
  { title: 'Capacitación Empresarial', description: 'Programas de formación, talleres y seminarios diseñados para fortalecer las competencias de tu equipo y mejorar la gestión empresarial.', icon: '🎓' },
  { title: 'Vinculación Comercial', description: 'A través de nuestra plataforma TER, conectamos empresas con proveedores certificados, generando más de 556 vinculaciones exitosas.', icon: '🤝' },
  { title: 'Formalización de Suplidores', description: 'Programa de acompañamiento para la formalización y certificación de proveedores del sector comercial dominicano.', icon: '✅' },
]

const fallbackInitiatives = [
  {
    title: 'Plataforma de Talento en el Retail (TER)',
    description: 'En 2023, fue creada la Plataforma de Talento en el Retail (TER): un espacio especializado dirigido a los actores de Gestión Humana del sector detallista formal. Se realizan seminarios, congresos, talleres, encuentros y ferias para captación de talentos.',
    image: '/images/logros/Creación-TER.png',
    stats: [{ label: 'Colaboradores impactados', value: '80+' }],
  },
  {
    title: 'Formalización de Empresas Proveedoras',
    description: 'Junto con el Ministerio de Industria, Comercio y MiPymes (MICM) hemos desarrollado desde 2021 programas de vinculación comercial mediante los cuales empresas MiPymes y artesanos se capacitan para tener relaciones comerciales exitosas con las empresas asociadas a nuestro gremio.',
    image: '/images/logros/Incentivo-Formalización-Empresas.png',
    stats: [{ label: 'Vinculaciones comerciales', value: '556+' }, { label: 'Desde', value: '2021' }],
  },
  {
    title: 'Código QR para Bomberos',
    description: 'ONEC junto con CARDNET desarrolló en octubre de 2021 un código QR que permite al Cuerpo de Bomberos del Distrito Nacional recibir donaciones de manera rápida, sencilla y segura.',
    image: '/images/logros/Creación-Código-QR-Bomberos.png',
    stats: [],
  },
  {
    title: 'Devolución de Gastos Educativos',
    description: 'ONEC junto al Centro Juan XXIII presentó un programa que benefició a las familias dominicanas y fomentó la formalización de colegios. Nuestra contribución clave fue la promulgación de la Ley 179-09 sobre deducción de gastos de educación.',
    image: '/images/logros/Incentiva-Devolución-Gastos.png',
    stats: [],
  },
  {
    title: 'Acuerdos Interinstitucionales',
    description: 'ONEC ha formalizado acuerdos estratégicos con INFOTEP, ABA, MICM, NUVI y ECORED para generar valor para sus afiliados mediante formación, comercio digital, empleo, reciclaje y sostenibilidad.',
    image: '/images/logros/Acuerdos-Interinstitucionales.png',
    stats: [{ label: 'Acuerdos firmados', value: '5+' }],
  },
]

const fallbackExperts = [
  {
    name: 'Alexis Hernández',
    role: 'CEO de Platinum Consulting',
    area: 'Comunicación y Liderazgo',
    bio: 'Apasionado de la comunicación y el entrenamiento... de la integración de equipos, el liderazgo, la gestión integral, la mejora continua, la calidad de servicio y experiencia del cliente. Con una trayectoria como docente, consultor y conferencista, combinado con posiciones en niveles directivos, que le han permitido "Enseñar desde el Hacer".',
    photo: '/images/expertos/Alexis-Hernandez.png'
  },
  {
    name: 'Darnetty Lugo Calderón',
    role: 'Socia, Cofundadora de IUS Mega Service',
    area: 'Derecho Laboral y Comercial',
    bio: 'Lic. en Derecho de UNAPAEC, Magister en Derecho de Trabajo y Administrativo, UTESA, posee un especialidad en Marketing Jurídico, de la Universidad Europea de Atlántico España. Ha participado en diversos congresos de Derecho de trabajo, diplomados en Gestión de Pymes, Derecho Civil y en materia inmobiliaria.',
    photo: '/images/expertos/Darnetty-Lugo.png'
  },
  {
    name: 'Francisco E. Figueroa Nigaglioni',
    role: 'Partner de Zendesk y Director General de PuntoShop',
    area: 'Tecnología y Soluciones Empresariales',
    bio: 'Matemático y cuenta con una maestría en el área de informática médica de Northwestern University, Evanston Chicago. Cuenta con más de 20 años de experiencia en el diseño, desarrollo e implementación de soluciones empresariales utilizando plataformas como PeopleSoft, Oracle, SAP, Microsoft, Salesforce y Zendesk.',
    photo: '/images/expertos/Francisco-Figueroa.png'
  },
  {
    name: 'Marian Pujals',
    role: 'Socia Gerente de la firma Dominguez Pujals',
    area: 'Derecho Procesal Civil',
    bio: 'Abogada egresada como Licenciada en Derecho (Magna Cum Laude) de la Pontificia Universidad Católica Madre y Maestra (PUCMM). Estudió posgrado en la maestría de Práctica Legal en PUCMM. Ha fungido como docente en la Universidad Iberoamericana (UNIBE) y PUCMM, Recinto Santo Tomas de Aquino (RSTA), en la materia de Derecho Procesal Civil.',
    photo: '/images/expertos/Marian-Pujals.png'
  },
  {
    name: 'Meiny González',
    role: 'Directora Comercial de Telecomunicaciones ONEMAX',
    area: 'Telecomunicaciones y Tecnología',
    bio: 'Es Ingeniera Electrónica y de Telecomunicaciones, con especializaciones en Gestión de Proyectos, Gerencia de Mercadeo y Gestión de Calidad. Actualmente concluyendo su Executive MBA en Barna Management School. Más de 15 años de ejercicio profesional desempeñando diversos roles en empresas de Telecomunicaciones y Tecnología en la República Dominicana.',
    photo: '/images/expertos/Meiny-González.png'
  },
]

// Fetch from Sanity with fallbacks
let sanityServices: any[] | null = null;
let sanityInitiatives: any[] | null = null;
let sanityExperts: any[] | null = null;
try { sanityServices = await fetchSanity(ALL_SERVICES_QUERY); } catch { sanityServices = null; }
try { sanityInitiatives = await fetchSanity(ALL_INITIATIVES_QUERY); } catch { sanityInitiatives = null; }
try { sanityExperts = await fetchSanity(EXPERT_MEMBERS_QUERY); } catch { sanityExperts = null; }

const services = sanityServices?.length
  ? sanityServices.map((s: any) => ({
      title: s.title,
      description: s.description || '',
      icon: s.icon || '',
    }))
  : fallbackServices;

const initiatives = sanityInitiatives?.length
  ? sanityInitiatives.map((i: any) => ({
      title: i.title,
      description: i.description || '',
      image: i.coverImage ? urlFor(i.coverImage).width(600).height(338).url() : '/images/logros/placeholder.png',
      stats: i.impactStats || [],
    }))
  : fallbackInitiatives;

const experts = sanityExperts?.length
  ? sanityExperts.map((e: any) => ({
      name: e.name,
      role: e.role || '',
      area: e.expertiseArea || '',
      bio: e.bio || '',
      photo: e.photo ? urlFor(e.photo).width(400).height(400).url() : undefined,
    }))
  : fallbackExperts;
---

<PageLayout
  title="Servicios"
  description="Conoce los servicios que ONEC ofrece a sus miembros: representación gremial, asesoría legal y fiscal, capacitación y vinculación comercial."
>
  <section class="pt-8 pb-4">
    <Container>
      <Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Servicios' }]} />
    </Container>
  </section>

  <section class="py-16">
    <Container>
      <SectionHeading
        title="Nuestros Servicios"
        subtitle="Soluciones integrales para el fortalecimiento de tu empresa"
      />
      <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((service) => (
          <ServiceCard title={service.title} description={service.description} icon={service.icon} />
        ))}
      </div>
    </Container>
  </section>

  <section class="py-16 bg-white">
    <Container>
      <SectionHeading
        title="Iniciativas Clave"
        subtitle="Programas que generan impacto real en el sector comercial"
      />
      <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-8">
        {initiatives.map((init) => (
          <InitiativeCard title={init.title} description={init.description} image={init.image} stats={init.stats} />
        ))}
      </div>
    </Container>
  </section>

  <section class="py-16">
    <Container>
      <SectionHeading
        title="Nuestros Expertos"
        subtitle="Profesionales especializados al servicio de nuestros miembros"
      />
      <div class="mt-12 space-y-6">
        {experts.map((expert) => (
          <ExpertProfile name={expert.name} role={expert.role} area={expert.area} bio={expert.bio} photo={expert.photo} />
        ))}
      </div>
    </Container>
  </section>

  <JoinCTA />
</PageLayout>
