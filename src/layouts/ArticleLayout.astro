---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/global/Header.astro';
import Footer from '@components/global/Footer.astro';

interface Props {
  title: string;
  description: string;
  image: string;
  publishedAt: string;
  category?: string;
}

const { title, description, image, publishedAt, category } = Astro.props;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image,
  datePublished: publishedAt,
  publisher: {
    '@type': 'Organization',
    name: 'ONEC',
    logo: {
      '@type': 'ImageObject',
      url: 'https://onec.org.do/logo.png',
    },
  },
  ...(category && { articleSection: category }),
};
---

<BaseLayout title={title} description={description} image={image} article={true} publishedAt={publishedAt}>
  <Header />
  <main id="main-content" class="py-12">
    <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <slot />
    </article>
  </main>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
</BaseLayout>
