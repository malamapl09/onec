---
import '@styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  article?: boolean;
  publishedAt?: string;
}

const {
  title,
  description,
  image = '/images/onec-logo.png',
  article = false,
  publishedAt,
} = Astro.props;

const fullTitle = `${title} | ONEC`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'ONEC',
  url: 'https://onec.org.do',
  logo: 'https://onec.org.do/images/onec-logo.png',
  foundingDate: '1997',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Torre Biltmore I, Suite 401, Av. Abraham Lincoln 1003',
    addressLocality: 'Santo Domingo',
    addressCountry: 'DO',
  },
  telephone: '+18096837229',
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#d12626" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="es_DO" />
    <meta property="og:site_name" content="ONEC" />
    {article ? (
      <>
        <meta property="og:type" content="article" />
        {publishedAt && <meta property="article:published_time" content={publishedAt} />}
      </>
    ) : (
      <meta property="og:type" content="website" />
    )}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  </head>
  <body class="bg-charcoal-50 text-charcoal-900 font-sans antialiased">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-onec-red focus:text-white focus:px-4 focus:py-2 focus:rounded-lg focus:text-sm focus:font-semibold">Saltar al contenido</a>
    <slot />
  </body>
</html>
