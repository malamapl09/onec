---

---

<!-- Form message container (hidden by default) -->
<div id="form-message" class="hidden rounded-lg px-4 py-3 text-sm font-medium mb-4" role="alert"></div>

<form id="contact-form" method="POST" action="/api/contact" class="space-y-6">
  <!-- Honeypot -->
  <input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />

  <!-- Nombre -->
  <div>
    <label for="nombre" class="block text-sm font-medium text-charcoal-900 mb-1">
      Nombre completo <span class="text-onec-red">*</span>
    </label>
    <input
      type="text"
      id="nombre"
      name="nombre"
      required
      maxlength="100"
      aria-describedby="nombre-desc"
      class="w-full rounded-lg border border-charcoal-100 px-4 py-3 text-charcoal-950 placeholder:text-charcoal-600/50 focus:ring-2 focus:ring-onec-red focus:border-transparent outline-none transition"
      placeholder="Juan Perez"
    />
    <span id="nombre-desc" class="sr-only">Campo requerido. Máximo 100 caracteres.</span>
  </div>

  <!-- Email -->
  <div>
    <label for="email" class="block text-sm font-medium text-charcoal-900 mb-1">
      Correo electrónico <span class="text-onec-red">*</span>
    </label>
    <input
      type="email"
      id="email"
      name="email"
      required
      maxlength="254"
      aria-describedby="email-desc"
      class="w-full rounded-lg border border-charcoal-100 px-4 py-3 text-charcoal-950 placeholder:text-charcoal-600/50 focus:ring-2 focus:ring-onec-red focus:border-transparent outline-none transition"
      placeholder="juan@empresa.com.do"
    />
    <span id="email-desc" class="sr-only">Campo requerido. Ingrese un correo electrónico válido.</span>
  </div>

  <!-- Empresa -->
  <div>
    <label for="empresa" class="block text-sm font-medium text-charcoal-900 mb-1">
      Empresa
    </label>
    <input
      type="text"
      id="empresa"
      name="empresa"
      maxlength="200"
      class="w-full rounded-lg border border-charcoal-100 px-4 py-3 text-charcoal-950 placeholder:text-charcoal-600/50 focus:ring-2 focus:ring-onec-red focus:border-transparent outline-none transition"
      placeholder="Nombre de su empresa"
    />
  </div>

  <!-- Teléfono -->
  <div>
    <label for="telefono" class="block text-sm font-medium text-charcoal-900 mb-1">
      Teléfono
    </label>
    <input
      type="tel"
      id="telefono"
      name="telefono"
      maxlength="20"
      class="w-full rounded-lg border border-charcoal-100 px-4 py-3 text-charcoal-950 placeholder:text-charcoal-600/50 focus:ring-2 focus:ring-onec-red focus:border-transparent outline-none transition"
      placeholder="809-555-0000"
    />
  </div>

  <!-- Asunto -->
  <div>
    <label for="asunto" class="block text-sm font-medium text-charcoal-900 mb-1">
      Asunto
    </label>
    <select
      id="asunto"
      name="asunto"
      class="w-full rounded-lg border border-charcoal-100 px-4 py-3 text-charcoal-950 focus:ring-2 focus:ring-onec-red focus:border-transparent outline-none transition bg-white"
    >
      <option value="" disabled selected>Seleccione un asunto</option>
      <option value="membresia">Membresía</option>
      <option value="consulta">Consulta general</option>
      <option value="servicios">Servicios</option>
      <option value="eventos">Eventos</option>
      <option value="otro">Otro</option>
    </select>
  </div>

  <!-- Mensaje -->
  <div>
    <label for="mensaje" class="block text-sm font-medium text-charcoal-900 mb-1">
      Mensaje <span class="text-onec-red">*</span>
    </label>
    <textarea
      id="mensaje"
      name="mensaje"
      required
      maxlength="2000"
      aria-describedby="mensaje-desc"
      rows="5"
      class="w-full rounded-lg border border-charcoal-100 px-4 py-3 text-charcoal-950 placeholder:text-charcoal-600/50 focus:ring-2 focus:ring-onec-red focus:border-transparent outline-none transition resize-y"
      placeholder="Escriba su mensaje aquí..."
    ></textarea>
    <span id="mensaje-desc" class="sr-only">Campo requerido. Máximo 2000 caracteres.</span>
  </div>

  <!-- Submit -->
  <button
    type="submit"
    id="submit-btn"
    class="bg-onec-red text-white w-full py-3 rounded-lg font-semibold hover:bg-onec-red-dark transition"
  >
    Enviar mensaje
  </button>
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const messageDiv = document.getElementById('form-message') as HTMLDivElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Loading state
    submitBtn.disabled = true;
    submitBtn.textContent = 'Enviando...';
    messageDiv.classList.add('hidden');

    try {
      const formData = new FormData(form);
      const res = await fetch('/api/contact', {
        method: 'POST',
        body: formData,
      });

      const data = await res.json();

      if (res.ok && data.success) {
        messageDiv.textContent = data.message;
        messageDiv.className = 'rounded-lg px-4 py-3 text-sm font-medium mb-4 bg-green-50 text-green-800 border border-green-200';
        form.reset();
      } else {
        messageDiv.textContent = data.error || 'Ocurrió un error inesperado.';
        messageDiv.className = 'rounded-lg px-4 py-3 text-sm font-medium mb-4 bg-red-50 text-red-800 border border-red-200';
      }
    } catch {
      messageDiv.textContent = 'Error de conexión. Por favor intenta de nuevo.';
      messageDiv.className = 'rounded-lg px-4 py-3 text-sm font-medium mb-4 bg-red-50 text-red-800 border border-red-200';
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Enviar mensaje';
    }
  });
</script>
