---
interface Props {
  title: string;
  subtitle?: string;
  centered?: boolean;
}

const { title, subtitle, centered = true } = Astro.props;
---

<div class:list={[centered && 'text-center']}>
  <h2 class="text-3xl md:text-4xl font-heading font-bold text-charcoal-950">
    {title}
  </h2>
  {subtitle && (
    <p class:list={['text-lg text-charcoal-600 mt-4 max-w-2xl', centered && 'mx-auto']}>
      {subtitle}
    </p>
  )}
  <div aria-hidden="true" class:list={['w-16 h-1 bg-onec-red rounded-full mt-4', centered && 'mx-auto']}></div>
</div>
