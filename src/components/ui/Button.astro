---
interface Props {
  variant?: 'primary' | 'secondary' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  class?: string;
  [key: string]: any;
}

const { variant = 'primary', size = 'md', href, class: className, ...rest } = Astro.props;

const variantClasses: Record<string, string> = {
  primary: 'bg-onec-red text-white hover:bg-onec-red-dark',
  secondary: 'bg-charcoal-950 text-white hover:bg-charcoal-900',
  outline: 'border-2 border-onec-red text-onec-red hover:bg-onec-red hover:text-white',
};

const sizeClasses: Record<string, string> = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3',
  lg: 'px-8 py-4 text-lg',
};

const baseClasses = 'rounded-lg font-semibold transition-colors inline-flex items-center justify-center focus-visible:ring-2 focus-visible:ring-onec-red focus-visible:ring-offset-2';
const classes = [baseClasses, variantClasses[variant], sizeClasses[size], className].filter(Boolean).join(' ');
---

{href ? (
  <a href={href} class={classes} {...rest}>
    <slot />
  </a>
) : (
  <button class={classes} {...rest}>
    <slot />
  </button>
)}
