---
/**
 * MemberDirectory - Displays real member logo strips.
 */
---

<div>
    <!-- Member logo strips -->
    <div class="space-y-1">
      {[1, 2, 3, 4, 5, 6].map((n) => (
        <img
          src={`/images/miembros/ONEC-Miembros_${n}.png`}
          alt="Miembros ONEC"
          class="w-full h-auto"
          loading="lazy"
          decoding="async"
        />
      ))}
    </div>

    <!-- Miembro Colaborador -->
    <div class="mt-8 pt-6 border-t border-charcoal-200 flex justify-center">
      <img
        src="/images/miembros/ONEC-Miembros_7.png"
        alt="Miembro Colaborador ONEC - ONEMAX Telecomunicaciones"
        class="h-auto max-w-sm"
        loading="lazy"
        decoding="async"
      />
    </div>
</div>
