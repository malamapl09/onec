---
import { navLinks } from '@data/navigation';

const currentYear = new Date().getFullYear();
---

<footer class="bg-charcoal-950 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <!-- Column 1: Brand -->
      <div>
        <a href="/">
          <img src="/images/onec-logo.png" alt="ONEC" class="h-10 w-auto brightness-0 invert" width="160" height="40" />
        </a>
        <p class="mt-4 text-sm text-white/70 leading-relaxed">
          Representamos al comercio dominicano desde 1997
        </p>
      </div>

      <!-- Column 2: Navigation -->
      <nav aria-label="Navegación del pie de página">
        <h3 class="text-sm font-semibold uppercase tracking-wider mb-4">Navegaci&oacute;n</h3>
        <ul class="space-y-3">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-white/70 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Column 3: Contact -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider mb-4">Contacto</h3>
        <ul class="space-y-3 text-sm text-white/70">
          <li>
            Torre Biltmore I, Suite 401<br />
            Av. Abraham Lincoln 1003<br />
            Santo Domingo, Rep. Dominicana
          </li>
          <li>
            <a href="tel:+18096837229" class="hover:text-white transition-colors">
              +1 (809) 683-7229
            </a>
          </li>
          <li>
            <a href="mailto:info@onec.org.do" class="hover:text-white transition-colors">
              info@onec.org.do
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 4: Legal -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider mb-4">Legal</h3>
        <ul class="space-y-3">
          <li>
            <a href="/politica-de-privacidad" class="text-sm text-white/70 hover:text-white transition-colors">
              Pol&iacute;tica de Privacidad
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-charcoal-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <p class="text-sm text-white/70 text-center">
        &copy; {currentYear} ONEC. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
