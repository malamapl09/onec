---
import { fetchSanity } from '@lib/sanity'
import { ALL_SERVICES_QUERY } from '../../../sanity/lib/queries'

const fallbackServices = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-onec-red" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0 0 12 9.75c-2.551 0-5.056.2-7.5.582V21" /></svg>`,
    title: 'Representación Gremial',
    description: 'Defendemos los intereses del comercio ante el gobierno y organismos reguladores.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-onec-red" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0 0 12 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 0 1-2.031.352 5.988 5.988 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.97Zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 0 1-2.031.352 5.989 5.989 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.97Z" /></svg>`,
    title: 'Asesoría Legal y Fiscal',
    description: 'Equipo de expertos en legislación comercial y tributaria dominicana.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-onec-red" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" /></svg>`,
    title: 'Capacitación Empresarial',
    description: 'Programas de formación y desarrollo para empresas miembro.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-onec-red" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" /></svg>`,
    title: 'Vinculación Comercial',
    description: 'Conectamos empresas con proveedores y oportunidades de negocio.',
  },
];

// Fetch from Sanity (first 4) with fallback
let sanityServices: any[] | null = null;
try { sanityServices = await fetchSanity(ALL_SERVICES_QUERY); } catch { sanityServices = null; }

// Default SVG icon for Sanity services that don't have an icon
const defaultIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-onec-red" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z" /></svg>`;

const services = sanityServices?.length
  ? sanityServices.slice(0, 4).map((s: any) => ({
      icon: s.icon || defaultIcon,
      title: s.title,
      description: s.description || '',
    }))
  : fallbackServices;
---

<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Heading -->
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-charcoal-950">
        Nuestros Servicios
      </h2>
      <p class="text-charcoal-600 text-lg mt-4 max-w-2xl mx-auto">
        Ofrecemos una amplia gama de servicios para fortalecer tu empresa
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {services.map((service) => (
        <div class="group">
          <div class="w-14 h-14 bg-onec-red-light rounded-xl flex items-center justify-center mb-5" aria-hidden="true">
            <Fragment set:html={service.icon} />
          </div>
          <h3 class="font-heading font-bold text-lg text-charcoal-950 mb-2">
            {service.title}
          </h3>
          <p class="text-charcoal-600 text-sm leading-relaxed mb-4">
            {service.description}
          </p>
          <a
            href="/servicios"
            class="text-onec-red text-sm font-semibold hover:text-onec-red-dark transition-colors inline-flex items-center gap-1"
            aria-label={`Conocer más sobre ${service.title}`}
          >
            Conocer más
            <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      ))}
    </div>

    <!-- Bottom link -->
    <div class="text-center mt-14">
      <a
        href="/servicios"
        class="inline-flex items-center gap-2 text-onec-red font-semibold hover:text-onec-red-dark transition-colors"
      >
        Ver todos los servicios
        <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </div>
</section>
