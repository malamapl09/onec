---

---

<section class="relative flex items-center overflow-hidden bg-charcoal-950">
  <!-- Banner image -->
  <div class="w-full">
    <img
      src="/images/banners/hero.png"
      alt="ONEC - Desde 1997 Fortaleciendo y Representando el sector comercial de nuestro país"
      class="w-full h-auto object-cover"
      width="1920"
      height="600"
      fetchpriority="high"
    />
  </div>

  <!-- CTA overlay at bottom -->
  <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent pt-20 pb-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="/membresia"
        class="inline-flex items-center justify-center bg-white text-onec-red font-semibold rounded-lg px-8 py-3.5 text-sm sm:text-base hover:bg-charcoal-50 transition-colors focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-black"
      >
        Hazte Miembro
      </a>
      <a
        href="/servicios"
        class="inline-flex items-center justify-center border-2 border-white text-white font-semibold rounded-lg px-8 py-3.5 text-sm sm:text-base hover:bg-white/10 transition-colors focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-black"
      >
        Conoce Nuestros Servicios
      </a>
    </div>
  </div>
</section>
