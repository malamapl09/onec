---
const foundingYear = 1997;
const years = new Date().getFullYear() - foundingYear;

const stats = [
  { value: `${years}+`, label: 'Años de trayectoria' },
  { value: '100+', label: 'Empresas miembro' },
  { value: '7', label: 'Sectores comerciales' },
  { value: '556+', label: 'Vinculaciones realizadas' },
];
---

<section class="bg-onec-red py-12 -mt-1">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      {stats.map((stat) => (
        <div class="text-center text-white">
          <p class="text-4xl md:text-5xl font-heading font-bold">{stat.value}</p>
          <p class="text-sm md:text-base text-white/80 mt-2">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
