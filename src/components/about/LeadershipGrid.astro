---
import { fetchSanity, urlFor } from '@lib/sanity'
import { ALL_TEAM_MEMBERS_QUERY } from '../../../sanity/lib/queries'

interface Member {
  name: string;
  role: string;
  bio: string;
  photo?: string;
}

interface Props {
  members?: Member[];
}

// Fetch non-expert team members from Sanity
let sanityMembers: any[] | null = null;
try {
  const allMembers = await fetchSanity<any[]>(ALL_TEAM_MEMBERS_QUERY);
  if (allMembers?.length) {
    sanityMembers = allMembers
      .filter((m: any) => !m.isExpert)
      .map((m: any) => ({
        name: m.name,
        role: m.role || '',
        bio: m.bio || '',
        photo: m.photo ? urlFor(m.photo).width(400).height(400).url() : undefined,
      }));
  }
} catch { sanityMembers = null; }

const { members: propMembers } = Astro.props;
const members: Member[] = propMembers?.length ? propMembers : (sanityMembers?.length ? sanityMembers : []);
---

<section class="py-16 sm:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {members.length === 0 ? (
      <div class="text-center py-12">
        <p class="text-charcoal-600 text-lg">Próximamente: Conoce a nuestro equipo directivo.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {members.map((member) => (
          <div class="group">
            <!-- Photo placeholder -->
            <div class="bg-charcoal-100 rounded-xl aspect-square flex items-center justify-center overflow-hidden">
              {member.photo ? (
                <img
                  src={member.photo}
                  alt={member.name}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              ) : (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-20 h-20 text-charcoal-600/30"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"
                  />
                </svg>
              )}
            </div>

            <h3 class="font-heading font-bold text-lg text-charcoal-950 mt-4">{member.name}</h3>
            <p class="text-onec-red text-sm font-medium">{member.role}</p>
            <p class="text-charcoal-600 text-sm mt-2">{member.bio}</p>
          </div>
        ))}
      </div>
    )}
  </div>
</section>
