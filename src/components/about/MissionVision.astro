---
const cards = [
  {
    title: 'Misión',
    content: 'Representar y defender los intereses del comercio organizado dominicano, ofreciendo servicios de valor que impulsen el desarrollo y la competitividad de nuestros miembros.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-onec-red" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" /></svg>`,
  },
  {
    title: 'Visión',
    content: 'Ser la organización líder y referente del sector comercial dominicano, reconocida por su capacidad de incidencia, innovación y servicio a sus miembros.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-onec-red" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.64 0 8.577 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.64 0-8.577-3.007-9.963-7.178z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
  },
  {
    title: 'Valores',
    content: '',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-onec-red" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg>`,
    values: ['Integridad', 'Servicio', 'Innovación', 'Colaboración', 'Excelencia'],
  },
];
---

<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
  {cards.map((card) => (
    <div class="bg-white rounded-xl p-8 shadow-sm">
      <div class="mb-4" aria-hidden="true" set:html={card.icon} />
      <div class="w-10 h-1 bg-onec-red rounded-full mb-4"></div>
      <h3 class="font-heading font-bold text-xl text-charcoal-950 mb-3">{card.title}</h3>
      {card.values ? (
        <ul class="space-y-2">
          {card.values.map((value) => (
            <li class="flex items-center gap-2 text-charcoal-600">
              <span class="w-1.5 h-1.5 bg-onec-red rounded-full flex-shrink-0"></span>
              {value}
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-charcoal-600 leading-relaxed">{card.content}</p>
      )}
    </div>
  ))}
</div>
