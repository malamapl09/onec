---
interface Props {
  name: string;
  role: string;
  area?: string;
  bio?: string;
  photo?: string;
}

const { name, role, area, bio, photo } = Astro.props;
---

<div class="bg-charcoal-950 rounded-xl overflow-hidden flex flex-col md:flex-row">
  <!-- Photo -->
  {photo ? (
    <img
      src={photo}
      alt={name}
      class="w-full md:w-40 h-48 md:h-40 object-cover flex-shrink-0"
      loading="lazy"
      width="160"
      height="192"
      decoding="async"
    />
  ) : (
    <div class="w-full md:w-40 h-48 md:h-40 bg-charcoal-800 flex-shrink-0 flex items-center justify-center">
      <svg class="w-10 h-10 text-charcoal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
      </svg>
    </div>
  )}

  <!-- Info -->
  <div class="flex-1 p-6">
    <h3 class="font-heading font-bold text-xl text-white">
      {name}
    </h3>
    <p class="text-charcoal-400 text-sm mt-1">
      {role}
    </p>

    <div class="w-12 h-0.5 bg-onec-red mt-3 mb-3"></div>

    {area && (
      <span class="inline-block bg-charcoal-800 text-charcoal-300 text-xs font-medium px-3 py-1 rounded-full mb-3">
        {area}
      </span>
    )}

    {bio && (
      <p class="text-white/80 mt-2 text-sm leading-relaxed">
        {bio}
      </p>
    )}
  </div>
</div>
