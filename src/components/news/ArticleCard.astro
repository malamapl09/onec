---
interface Props {
  title: string;
  excerpt: string;
  slug: string;
  date: string;
  category?: string;
  image?: string;
}

const { title, excerpt, slug, date, category, image } = Astro.props;
---

<a href={`/noticias/${slug}`} class="block bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition group">
  <!-- Image -->
  <div class="aspect-video bg-charcoal-100 overflow-hidden">
    {image ? (
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition duration-300"
        loading="lazy"
        width="600"
        height="338"
        decoding="async"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center group-hover:scale-105 transition duration-300">
        <svg class="w-12 h-12 text-charcoal-600/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5" />
        </svg>
      </div>
    )}
  </div>

  <!-- Content -->
  <div class="p-6">
    {category && (
      <span class="inline-block bg-onec-red-light text-onec-red text-xs font-semibold px-2.5 py-0.5 rounded-full">
        {category}
      </span>
    )}

    <h3 class="font-heading font-semibold text-lg mt-2 text-charcoal-950 group-hover:text-onec-red transition">
      {title}
    </h3>

    <p class="text-charcoal-600 text-sm mt-2 line-clamp-2">
      {excerpt}
    </p>

    <time class="block text-xs text-charcoal-600 mt-4" datetime={date}>
      {new Date(date).toLocaleDateString('es-DO', { year: 'numeric', month: 'long', day: 'numeric' })}
    </time>
  </div>
</a>
