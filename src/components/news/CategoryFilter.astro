---
interface Props {
  categories: Array<{ title: string; slug: string }>;
  activeCategory?: string;
}

const { categories, activeCategory } = Astro.props;
---

<nav class="overflow-x-auto pb-2 -mb-2" aria-label="Filtrar por categoría">
  <div class="flex gap-2 min-w-max">
    <!-- "Todos" button -->
    <a
      href="/noticias"
      class:list={[
        'inline-block px-4 py-2 rounded-full text-sm font-medium transition whitespace-nowrap',
        !activeCategory
          ? 'bg-onec-red text-white'
          : 'bg-charcoal-100 text-charcoal-600 hover:bg-charcoal-200',
      ]}
    >
      Todos
    </a>

    <!-- Category buttons -->
    {categories.map((cat) => (
      <a
        href={`/noticias?categoria=${cat.slug}`}
        class:list={[
          'inline-block px-4 py-2 rounded-full text-sm font-medium transition whitespace-nowrap',
          activeCategory === cat.slug
            ? 'bg-onec-red text-white'
            : 'bg-charcoal-100 text-charcoal-600 hover:bg-charcoal-200',
        ]}
      >
        {cat.title}
      </a>
    ))}
  </div>
</nav>
